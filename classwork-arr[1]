import java.util.Scanner;
class Main {
    public static void main(String[] args) 
    {
      Scanner ap=new Scanner(System.in);
      int n=ap.nextInt();
      int arr[]=new int[n];
      for(int i=0;i<n;i++)
      {
        arr[i]=ap.nextInt();
      }
      for(int i=0;i<n;i++)
      {
        System.out.println(arr[i]);
      }
    }
}
