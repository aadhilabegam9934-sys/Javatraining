import java.util.Scanner;
class Solution
{
    public static void main(String args[])
    {
        int a,b,c,d,e,f;
        Scanner ap=new Scanner(System.in);
        a=ap.nextInt();
        b=ap.nextInt();
        c=a+b;
        d=a-b;
        e=a*b;
        f=a/b;
        System.out.println(c);
        System.out.println(d);
        System.out.println(e);
        System.out.println(f);
    }}
