import java.util.*;
class Solution{
    public static void main(String[] args) 
    {
      Scanner ap=new Scanner(System.in);
      int n=ap.nextInt();
      int arr[]=new int[n];
      int sum=0;
      for(int i=0;i<n;i++)
      {
        arr[i]=ap.nextInt();
      }
      for(int i=0;i<n;i++)
      {
        sum=sum+arr[i];
        
      } System.out.println("Sum of elements:"+sum/n);
    }
}
